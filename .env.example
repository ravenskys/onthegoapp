# Public site URL (no trailing slash)—used for SEO canonical URLs, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional: Google Search Console HTML tag verification value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Optional routing provider for dispatch-based travel defaults in scheduler
ROUTING_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=
DISPATCH_ORIGIN_LAT=
DISPATCH_ORIGIN_LNG=
